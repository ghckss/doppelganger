APP_HOST=127.0.0.1
APP_PORT=4318
APP_BASE_URL=http://127.0.0.1:4318
APP_ENCRYPTION_KEY=
SESSION_SECRET=
DATABASE_PATH=.local/agent.db

SLACK_READ_TOKEN=Slack read token for search and thread history
SLACK_WRITE_TOKEN=Slack write token for replies and reactions
SLACK_USER_ID=Slack user id to monitor mentions for
SLACK_INITIAL_LOOKBACK_MINUTES=Initial poll lookback window in minutes
SLACK_SEARCH_PAGE_SIZE=Slack search page size per API call
SLACK_SEARCH_MAX_PAGES=Maximum Slack search pages per poll
SLACK_IGNORE_CHANNELS=Comma-separated channel ids or names to ignore
SLACK_CODE_KEYWORDS_PATH=Path to code-keyword rules JSON file
SLACK_CODE_ANALYSIS_MAX_FINDINGS=Maximum findings saved from code analysis

OPENAI_API_KEY=OpenAI API key when using openai provider
OPENAI_MODEL=OpenAI model name for text generation
OPENAI_BASE_URL=OpenAI compatible base URL

GITHUB_TOKEN=GitHub token for PR polling and review posting
GITHUB_OWNER=GitHub organization or owner
GITHUB_REPOSITORIES=Comma-separated target repositories
FIGMA_FILE_URL=Base Figma file URL for opening generated UI context
FIGMA_PLUGIN_ID=Published Figma plugin id for one-click run link
FIGMA_PLUGIN_URL=Optional full Figma plugin URL override (takes precedence over FIGMA_PLUGIN_ID)

WORKSPACE_ALLOWLIST=Optional extra allowed workspace paths (comma-separated)
AGENT_PROVIDER=Default code execution agent (codex or claude)
CODEX_COMMAND=Codex CLI executable command
CLAUDE_COMMAND=Claude CLI executable command
EXTERNAL_AGENT_COMMAND=External agent CLI executable command for GitHub review
GENERATION_PROVIDER=Default generation provider (cli/openai/fallback/external)
GENERATION_AGENT_PROVIDER=Default CLI generation agent (codex/claude)
GENERATION_TIMEOUT_SECONDS=Global generation timeout seconds (0 disables)
SLACK_GENERATION_TIMEOUT_SECONDS=Slack scope timeout seconds (empty uses global, 0 disables)
GITHUB_REVIEW_TIMEOUT_SECONDS=GitHub review scope timeout seconds (empty uses global, 0 disables)
CODE_PLANNING_TIMEOUT_SECONDS=Code planning scope timeout seconds (empty uses global, 0 disables)
MEETING_NOTES_TIMEOUT_SECONDS=Meeting notes scope timeout seconds (empty uses global, 0 disables)
SLACK_GENERATION_PROVIDER=Slack scope provider override
SLACK_GENERATION_AGENT_PROVIDER=Slack scope CLI agent override
GITHUB_REVIEW_PROVIDER=GitHub review scope provider override
GITHUB_REVIEW_AGENT_PROVIDER=GitHub review scope CLI agent override
CODE_PLANNING_PROVIDER=Code planning scope provider override
CODE_PLANNING_AGENT_PROVIDER=Code planning scope CLI agent override
MEETING_NOTES_PROVIDER=Meeting notes scope provider override
MEETING_NOTES_AGENT_PROVIDER=Meeting notes scope CLI agent override
APP_CORS_ORIGINS=Optional additional allowed browser origins for CORS (comma-separated)
